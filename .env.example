#### Default Game Manager Settings
# Copy this file and name it .env and the app will load it on startup

# Dockerhub username
DOCKER_USER = "jibby"
# Dockerhub repo name
DOCKER_REPO = "flappyrace"
# Maximum amount of times the manager will try creating a server if it fails
MAX_CONTAINER_RETRIES = 10
# Maximum amount of servers that can run at once
MAX_RUNNING_SERVERS = 20
# Maximum amount of docker image tags to support multiple older versions
MAX_TAGS = 5

# Connection mode: "ports" (direct host ports) or "traefik" (route via Traefik reverse proxy)
CONNECTION_MODE = "ports"

#### Ports mode settings
# Docker secrets volume containing HTTPS server certificates
SECRETS_VOLUME = "flappy-backend_nginx_secrets"
# Port range for game servers (must match firewall rules)
GAME_SERVER_PORT_MIN = 7000
GAME_SERVER_PORT_MAX = 7999

#### Traefik mode settings
# Docker network Traefik uses to reach containers
TRAEFIK_NETWORK = "frontend"
# Fixed port that game server containers listen on internally (Traefik routes to this)
TRAEFIK_GAME_PORT = 31400
# Game slug used in the URL path: /games/<GAME_SLUG>/<game_id>/ws
GAME_SLUG = "flappy-race"
